# ==============================================================================
# BIKE MARKETPLACE — Mẫu biến môi trường
# ==============================================================================
# HƯỚNG DẪN:
#   1. Sao chép file này thành file .env:  cp .env.example .env
#   2. Điền giá trị thật vào file .env vừa tạo
#   3. KHÔNG commit file .env lên Git (đã có trong .gitignore)
#   4. File .env.example này thì PHẢI commit để mọi người cùng biết cấu hình
# ==============================================================================


# ── Máy chủ ──────────────────────────────────────────────────────────────────
# Cổng Express sẽ lắng nghe. Mặc định là 5000 nếu để trống.
PORT=5000


# ── Cơ sở dữ liệu (MySQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=bike_marketplace


# ── JSON Web Token (JWT) ──────────────────────────────────────────────────────
# JWT_SECRET: Chuỗi bí mật dùng để ký và xác thực token.
#   - Dùng chuỗi ngẫu nhiên, đủ dài (khuyến nghị >= 32 ký tự).
#   - Ví dụ tạo nhanh trên terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   - TUYỆT ĐỐI không dùng giá trị đơn giản như "secret" hay "123456".
JWT_SECRET=

# JWT_EXPIRES_IN: Thời gian sống của token.
#   - Định dạng: "1d" (1 ngày), "7d" (7 ngày), "2h" (2 giờ), "30m" (30 phút)...
JWT_EXPIRES_IN=1d


# ── Upload ảnh (Local Disk) ───────────────────────────────────────────────────
# MAX_FILE_SIZE_MB: Dung lượng tối đa mỗi ảnh (tính bằng MB). Mặc định: 5
MAX_FILE_SIZE_MB=5

# MAX_FILES_PER_POST: Số ảnh tối đa mỗi tin đăng. Mặc định: 5
MAX_FILES_PER_POST=5
